# OmniLegal real RAG runtime
OMNILEGAL_RUNTIME=verified_langgraph_rag
OMNILEGAL_VECTOR_BACKEND=server_qdrant
OMNILEGAL_ALLOW_SQLITE_FALLBACK=1
QDRANT_URL=http://localhost:6333

# Core retrieval models
EMBED_MODEL=BAAI/bge-m3
RERANKER=BAAI/bge-reranker-v2-m3
OMNILEGAL_EMBED_PROVIDER=auto
OMNILEGAL_EMBEDDING_DIM=384
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
FASTEMBED_DIM=384

OMNILEGAL_USE_DENSE_RETRIEVAL=1
OMNILEGAL_ENABLE_HEAVY_MODELS=0
OMNILEGAL_ENABLE_HF_PROVIDER=0
OMNILEGAL_ENABLE_GLINER=0
OMNILEGAL_ENABLE_ZERO_SHOT=0
OMNILEGAL_ENABLE_LEGAL_NER=0
OMNILEGAL_ENABLE_LLM_ENTITY_EXTRACTION=0
OMNILEGAL_ENABLE_LEGAL_GPT2_QUERY_ASSIST=0
OMNILEGAL_ENABLE_DSPY=0
OMNILEGAL_ENABLE_CONTEXTUAL_RETRIEVAL=0

# Generation providers
EMERGENT_LLM_KEY=your_emergent_llm_key_here
EMERGENT_LLM_PROVIDER=anthropic
EMERGENT_LLM_MODEL=claude-sonnet-4-5-20250929

GROQ_LLM=llama-3.3-70b-versatile
GROQ_API_KEY=your_groq_api_key_here
GROQ_REQUEST_TIMEOUT_SECONDS=45

GEMINI_API_KEY=your_gemini_api_key_here
OMNILEGAL_GEMINI_FALLBACK_MODEL=gemini-2.5-flash
OMNILEGAL_ENABLE_GEMINI_FALLBACK=1
GEMINI_REFINER_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite
GEMINI_REQUEST_TIMEOUT_SECONDS=20

OMNILEGAL_OLLAMA_BASE_URL=http://localhost:11434
OMNILEGAL_OLLAMA_MODEL=qwen2.5:7b-instruct
LOCAL_LLM=qwen2.5:7b-instruct

OMNILEGAL_DEFAULT_ANSWER_MODE=tourist_practical
OMNILEGAL_RETRIEVAL_DEADLINE_SECONDS=40

CHAINLIT_HOST=0.0.0.0
CHAINLIT_PORT=3000

# External source APIs
HF_TOKEN=your_hf_token_here
COURTLISTENER_TOKEN=your_courtlistener_token_here
GOVINFO_API_KEY=your_govinfo_api_key_here
DATAGOV_API_KEY=your_datagov_api_key_here
INDIAN_KANOON_API_KEY=your_indian_kanoon_api_key_here
INDIAN_KANOON_API_TOKEN=your_indian_kanoon_api_token_here
CORE_API_KEY=your_core_api_key_here
OPENALEX_API_KEY=your_openalex_api_key_here

OMNILEGAL_ENABLE_CONFLICT_LLM=1
OMNILEGAL_CONFLICT_PROVIDER=auto
OMNILEGAL_ENABLE_CITATION_VERIFICATION=1
OMNILEGAL_ENABLE_IRAC_PER_JURISDICTION=1
