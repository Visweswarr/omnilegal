# OmniLegal real RAG runtime
OMNILEGAL_RUNTIME=verified_langgraph_rag
OMNILEGAL_VECTOR_BACKEND=embedded_qdrant
OMNILEGAL_ALLOW_SQLITE_FALLBACK=0
QDRANT_URL=http://localhost:6333

# Core retrieval models
EMBED_MODEL=BAAI/bge-m3
RERANKER=BAAI/bge-reranker-v2-m3

# Runtime model hygiene: keep failing HF/GLiNER/zero-shot models out of chat
OMNILEGAL_ENABLE_HEAVY_MODELS=0
OMNILEGAL_ENABLE_HF_PROVIDER=0
OMNILEGAL_ENABLE_GLINER=0
OMNILEGAL_ENABLE_ZERO_SHOT=0
OMNILEGAL_ENABLE_LEGAL_NER=0
OMNILEGAL_ENABLE_LLM_ENTITY_EXTRACTION=0
OMNILEGAL_ENABLE_LEGAL_GPT2_QUERY_ASSIST=0
OMNILEGAL_ENABLE_DSPY=0

# Generation providers. Use one working primary plus one fallback.
GROQ_LLM=llama-3.3-70b-versatile
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OMNILEGAL_OLLAMA_BASE_URL=http://localhost:11434
OMNILEGAL_OLLAMA_MODEL=qwen2.5:7b-instruct

# Optional source APIs for offline ingestion/discovery
GOVINFO_API_KEY=
COURTLISTENER_TOKEN=
INDIAN_KANOON_API_TOKEN=
CONGRESS_API_KEY=
DATAGOV_API_KEY=
SEC_USER_AGENT=
