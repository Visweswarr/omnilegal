created": "2019-01-09T10:30:57.648261", "metadata_modified": "2023-03-21T18:32:47.687636", "name": "my-bills", "notes": "\u05de\u05d0\u05d2\u05e8 \u05d4\u05de\u05e6\u05d9\u05d2 \u05d0\u05ea \u05db\u05dc \u05d4\u05e6\u05e2\u05d5\u05ea \u05d4\u05d7\u05d5\u05e7 \u05e9\u05d4\u05d5\u05d2\u05e9\u05d5 \u05de\u05d0\u05d6 \u05d4\u05db\u05e0\u05e1\u05ea \u05d4\u05e8\u05d0\u05e9\u05d5\u05e0\u05d4 \u05d5\u05e2\u05d3 \u05d4\u05db\u05e0\u05e1\u05ea \u05d4\u05e0\u05d5\u05db\u05d7\u05d9\u05ea, \u05d1\u05de\u05e6\u05d1\u05d9\u05dd \u05d0\u05dc\u05d4: \u05d1\u05d7\u05e7\u05d9\u05e7\u05d4 - \u05d4\u05e6\u05e2\u05d5\u05ea \u05d7\u05d5\u05e7 \u05e9\u05d4\u05dc\u05d9\u05da \u05d7\u05e7\u05d9\u05e7\u05ea\u05df \u05d8\u05e8\u05dd \u05d4\u05d5\u05e9\u05dc\u05dd \u05d0\u05d5 \u05e0\u05e2\u05e6\u05e8, \u05ea\u05d5\u05da \u05e4\u05d9\u05e8\u05d5\u05d8 \u05e9\u05dc\u05d1 \u05d4\u05d7\u05e7\u05d9\u05e7\u05d4 \u05e9\u05d1\u05d5 \u05d4\u05df \u05e0\u05de\u05e6\u05d0\u05d5\u05ea (\u05d1\u05de\u05dc\u05d9\u05d0\u05d4 \u05d0\u05d5 \u05d1\u05d5\u05d5\u05e2\u05d3\u05d4 \u05d5\u05dc\u05e7\u05e8\u05d0\u05ea \u05d0\u05d9\u05d6\u05d5 \u05e7\u05e8\u05d9\u05d0\u05d4) \u05d4\u05d7\u05e7\u05d9\u05e7\u05d4 \u05e0\u05e2\u05e6\u05e8\u05d4 - \u05d4\u05e6\u05e2\u05d5\u05ea \u05d7\u05d5\u05e7 \u05e9\u05d4\u05dc\u05d9\u05da \u05d7\u05e7\u05d9\u05e7\u05ea\u05df \u05e0\u05e2\u05e6\u05e8 (\u05dc\u05de\u05e9\u05dc \u05d4\u05e6\u05e2\u05ea \u05d7\u05d5\u05e7 \u05e9\u05dc\u05d0 \u05d4\u05ea\u05e7\u05d1\u05dc\u05d4 \u05d1\u05d0\u05d7\u05ea \u05d4\u05e7\u05e8\u05d9\u05d0\u05d5\u05ea, \u05d4\u05e6\u05e2\u05ea \u05d7\u05d5\u05e7 \u05e9\u05d7\u05d1\u05e8 \u05d4\u05db\u05e0\u05e1\u05ea \u05d4\u05d9\u05d7\u05d9\u05d3 \u05e9\u05d4\u05d2\u05d9\u05e9 \u05d0\u05d5\u05ea\u05d4 \u05d7\u05d6\u05e8 \u05d1\u05d5 \u05de\u05de\u05e0\u05d4, \u05d4\u05e6\u05e2\u05ea \u05d7\u05d5\u05e7 \u05e9\u05de\u05d5\u05d6\u05d2\u05d4 \u05e2\u05dd \u05d4\u05e6\u05e2\u05ea \u05d7\u05d5\u05e7 \u05d0\u05d7\u05e8\u05ea \u05d0\u05d5 \u05d4\u05e6\u05e2\u05ea \u05d7\u05d5\u05e7 \u05e9\u05d4\u05dc\u05d9\u05db\u05d9 \u05d7\u05e7\u05d9\u05e7\u05ea\u05d4 \u05d8\u05e8\u05dd \u05d4\u05d5\u05e9\u05dc\u05de\u05d5 \u05d5\u05d4\u05db\u05e0\u05e1\u05ea \u05d4\u05ea\u05e4\u05d6\u05e8\u05d4) \u05d4\u05d7\u05e7\u05d9\u05e7\u05d4 \u05d4\u05d5\u05e9\u05dc\u05de\u05d4 - \u05d4\u05e6\u05e2\u05d5\u05ea \u05d7\u05d5\u05e7 \u05e9\u05d4\u05ea\u05e7\u05d1\u05dc\u05d5 \u05d1\u05e7\u05e8\u05d9\u05d0\u05d4 \u05d4\u05e9\u05dc\u05d9\u05e9\u05d9\u05ea \u05d5\u05d4\u05dc\u05d9\u05da \u05d7\u05e7\u05d9\u05e7\u05ea\u05df \u05d4\u05d5\u05e9\u05dc\u05dd. \r\n\u05d0\u05e8\u05db\u05d9\u05d5\u05df \u05d4\u05db\u05e0\u05e1\u05ea \u05e4\u05d5\u05e2\u05dc \u05dc\u05d4\u05e9\u05dc\u05de\u05ea \u05e0\u05ea\u05d5\u05e0\u05d9\u05dd \u05d5\u05de\u05e1\u05de\u05db\u05d9\u05dd \u05d7\u05e1\u05e8\u05d9\u05dd.\r\n", "num_resources": 1, "num_tags": 10, "organization": {"id": "9c6d5fe0-efa1-48fa-95c4-ae4436613dba", "name": "knesset", "title": "\u05d4\u05db\u05e0\u05e1\u05ea", "type": "organization", "description": "", "image_url": "2021-08-17-143126.182741ministryofenergy.png", "created": "2015-12-07T10:34:59.343855", "is_organization": true, "approval_status": "approved", "state": "active"}, "owner_org": "9c6d5fe0-efa1-48fa-95c4-ae4436613dba", "private": false, "remark": "", "state": "active", "title": "\u05db\u05dc \u05d4\u05e6\u05e2\u05d5\u05ea \u05d4\u05d7\u05d5\u05e7", "type": "dataset", "url": "https://main.knesset.gov.il/Pages/default.aspx", "version": "", "extras": [{"key": "Accessibility", "value": "Accessible"}, {"key": "ContainPrivateData", "value": "No"}, {"key": "is_geographic", "value": "No"}], "resources": [{"Frequency": "NA", "cache_last_updated": null, "cache_url": null, "category": "archive", "created": "2019-01-09T10:31:07.512067", "datastore_active": false, "datastore_contains_all_records_of_source_file": false, "description": "", "format": "", "hash": "", "how_update": "NA", "id": "d4091ded-06b1-41cd-b7e0-454e5fb81029", "last_modified": null, "metadata_